<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.ActivityListController">

    <top>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10" left="15" right="15" top="15" />
            </padding>

            <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Activity List" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <TextField fx:id="filterField" prefWidth="420.0" promptText="Enter any key words (Activity, Organizer, Date, Time, Location, or Gender)" />

                <Button onAction="#handleFilter" prefWidth="90.0" text="Apply Filter" />

                <Button onAction="#handleClearFilter" prefWidth="90.0" text="Clear" />
            </HBox>

            <Label fx:id="messageLabel" style="-fx-font-size: 13px;" text="Please select an activity." />
        </VBox>
    </top>

    <center>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>

            <TableView fx:id="activityTable" prefHeight="350.0" prefWidth="650.0">
                <columns>
                    <TableColumn fx:id="colName" prefWidth="120.0" text="Activity Name" />
                    <TableColumn fx:id="colOrganizer" prefWidth="100.0" text="Organizer" />
                    <TableColumn fx:id="colDate" prefWidth="100.0" text="Date" />
                    <TableColumn fx:id="colTimeSlot" prefWidth="120.0" text="Time Slot" />
                    <TableColumn fx:id="colLocation" prefWidth="140.0" text="Location" />
                    <TableColumn fx:id="colGender" prefWidth="90.0" text="Gender" />
                    <TableColumn fx:id="colStatus" prefWidth="70.0" text="Status" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20" left="15" right="15" top="10" />
            </padding>

            <Button onAction="#handleJoin" prefWidth="100.0" text="Join" />

            <Button onAction="#handleEditActivity" prefWidth="100.0" text="Edit" />

            <Button onAction="#handleBack" prefWidth="100.0" text="Back" />
        </HBox>
    </bottom>

</BorderPane>
